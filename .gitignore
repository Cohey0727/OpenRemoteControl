# dependencies
node_modules/
.pnp.*

# build artifacts
dist/
*.tsbuildinfo
.open-rc/

# local stream-json capture samples (debugging artifacts, never tracked)
captures/
*.jsonl

# secrets / config
*.key
*.pem
.env
.env.local

# browser-automation debug artifacts (Playwright MCP)
.playwright-mcp/

# editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# logs
*.log

# Environment-specific deploy kits live OUTSIDE the codebase: anything
# under vps/ is one operator's local tooling (hosts, domains, scripts)
# and is never committed. The repo documents deployment patterns in
# docs/ only (see docs/docker.md); the code depends on no environment.
vps/

# Per-test scratch directories created by attach-state and attach-hooks
# tests (see tests/attach-state.test.ts, tests/attach-hooks.test.ts).
# They hold per-run fixture UUIDs and are recreated on every test run;
# they must never be tracked.
tests/.tmp-*/

# Local working notes (owner scratch, never repo material)
issue.md
